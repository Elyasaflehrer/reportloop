# Root-level package files exist only as a host for the supabase CLI
# devDep (installed by `just setup-deps`). The repo isn't a Node project
# at the root — backend/, frontend/, and tests/ are. Leading slash anchors
# to root so subdir package.json files stay tracked.
/package.json
/package-lock.json

# === Environments / secrets ===
.env
.env.*
!.env.example
!.env.*.example
.envrc
.env.keys
.env.local
.env.*.local
.venv
env/
venv/
ENV/

# === Editors / AI tools ===
.cursorignore
.cursorindexingignore
.vscode-test
.agents/
**/.agents/
skills-lock.json
**/skills-lock.json

