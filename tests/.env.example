# Test package env. Copy to `.env` (gitignored) and fill in.

# URL of the running backend dev server.
# The backend must be started separately (cd ../backend && npm run dev).
BACKEND_URL=http://localhost:8082

# Same Supabase JWT secret the backend validates against. Used to sign
# test JWTs locally (auth.ts in src/helpers).
# Find this in backend/.env as SUPABASE_JWT_SECRET.
SUPABASE_JWT_SECRET=

# Postgres connection string for the test DB. Tests connect directly via
# Prisma for cleanup + assertions (NOT for behavior — behavior goes through
# the API). Should point at the same DB the backend dev server is using.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
