# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime via PgBouncer)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (used by Prisma for migrations — bypasses PgBouncer)
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Found in: Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ─── REDIS ────────────────────────────────────────────────────────────────────
# Single connection string — works with Railway Redis, Upstash, ElastiCache, or local
# Set to "mock" (or omit entirely) to use an in-memory mock — no Redis instance needed.
# Useful for dev/cloud environments where a real Redis is expensive.
REDIS_URL=redis://localhost:6379

# ─── SMS PROVIDER ─────────────────────────────────────────────────────────────
# Which provider to use. Only 'twilio' is implemented. See docs/adding-sms-provider.md to add more.
SMS_PROVIDER=twilio

# Twilio (required if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# URL this server is reachable at — used as the Twilio statusCallback base
APP_BASE_URL=http://localhost:3000
# Allowed CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:5500

# ─── SMS LIMITS ───────────────────────────────────────────────────────────────
# Max SMS character length (3 concatenated segments = 459 chars)
SMS_MAX_LENGTH=459

# ─── BROADCAST ENGINE ─────────────────────────────────────────────────────────
# How many broadcast jobs run simultaneously
BROADCAST_CONCURRENCY=3
# How many times to retry a failed broadcast job
BROADCAST_RETRY_COUNT=3
# Initial retry delay in ms (doubles on each attempt)
BROADCAST_RETRY_DELAY_MS=5000

# ─── CONVERSATION ENGINE ──────────────────────────────────────────────────────
# Minutes of silence before sending a reminder SMS
CONVERSATION_REMINDER_INTERVAL_MINUTES=60
# How many reminder SMSes before marking the conversation timed_out
CONVERSATION_REMINDER_COUNT=2
# Minutes a conversation can stay in 'processing' before recovery worker resets it
CONVERSATION_STUCK_TIMEOUT_MINUTES=30
# Days to retain completed conversations (0 = keep forever)
CONVERSATION_RETENTION_DAYS=0

# ─── AI PROMPT OVERRIDES ──────────────────────────────────────────────────────
# Optional. Override the default prompts in services/ai/prompts.ts without
# changing code — useful for A/B testing prompt variants. Templates use
# {{name}} placeholders. If unset, the defaults from prompts.ts are used.
#
# Required placeholders per prompt:
#   AI_PROMPT_INITIAL: {{maxLength}}, {{questions}}
#   AI_PROMPT_SHORTEN: {{maxLength}}, {{previousAttempt}}
#   AI_PROMPT_EXTRACT: {{questions}}, {{conversation}}
#
# Example (uncomment + edit to test a variant):
# AI_PROMPT_INITIAL="Write a brief SMS. Under {{maxLength}} chars. Questions:\n{{questions}}"

# ─── SMS LOGGING ──────────────────────────────────────────────────────────────
# When true, the Phase 3 SMS log lines include the message body. Off by
# default — bodies are PII and shouldn't end up in Cloud Logging. Only set to
# true for local debugging; NEVER true in production.
LOG_SMS_BODY=false

# ─── BULLMQ WORKER TUNING ─────────────────────────────────────────────────────
# Applied to every BullMQ Worker via defaultWorkerOpts (see jobs/queue.ts).
# Raise stalledInterval to cut Redis polling on metered providers (Upstash etc).
# How often each worker scans for stalled jobs, in ms (BullMQ default: 30000)
WORKER_STALLED_INTERVAL_MS=300000
# How many times a job can stall before it's moved to failed
WORKER_MAX_STALLED_COUNT=1
# Per-worker metrics history; 0 disables metric writes entirely
WORKER_METRICS_MAX_DATA_POINTS=0
