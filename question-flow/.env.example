# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567

# ── Workflow tuning ───────────────────────────────────────────────────────────
# How many reminder messages before giving up (default: 3)
MAX_REMINDERS=3
# Seconds to wait between sending questions and the first reminder check
# 3600 = 1 hour.  Use a small value (e.g. 60) for local testing.
REMINDER_INTERVAL_SECONDS=3600
# Maximum number of partial-answer recycle loops (default: 5)
MAX_CYCLES=5

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── MCP server (standalone mode only) ────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ── Database (future feature — leave db_enabled=false until ready) ────────────
DB_ENABLED=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/question_flow

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=question_flow.log